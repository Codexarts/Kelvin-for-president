<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kelvin Saitabau — President of Gapla</title>
<meta name="description" content="Kelvin Saitabau for President of Gapla — a new nation built by Gen Z, open to everyone on Earth. Vote now.">
<meta property="og:title" content="Kelvin Saitabau for President of Gapla">
<meta property="og:description" content="A new sovereign nation. Built by Gen Z. Open to every nationality. Vote now.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&family=Cinzel:wght@400;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet">

<style>
/* ━━━ TOKENS ━━━ */
:root{
  --black:#080706; --dark:#100F0C; --dark2:#161410; --card:#1C1A16;
  --gold:#C8A96E; --gold2:#A8883E; --gold-lt:#E8C98E;
  --cream:#F2EBE0; --cream2:#E8DDD0; --white:#FAFAF8;
  --muted:#8A8070; --border:rgba(200,169,110,0.15); --border2:rgba(200,169,110,0.08);
  --wa:#25D366; --yt:#FF0000;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--black);color:var(--cream);font-family:'Inter',sans-serif;font-weight:300;font-size:16px;line-height:1.7;overflow-x:hidden;}
img{display:block;max-width:100%;}
a{text-decoration:none;color:inherit;}

/* ━━━ NAV ━━━ */
nav{
  position:sticky;top:0;z-index:900;height:60px;
  display:flex;align-items:center;justify-content:space-between;padding:0 6%;
  background:rgba(8,7,6,0.97);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border2);
}
.nav-logo{font-family:'Cinzel',serif;font-size:0.82rem;letter-spacing:0.25em;color:var(--gold);}
.nav-links{display:flex;gap:1.75rem;list-style:none;}
.nav-links a{font-size:0.62rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);transition:color 0.2s;}
.nav-links a:hover{color:var(--gold);}
.nav-socials{display:flex;gap:0.75rem;align-items:center;}
.ns{width:32px;height:32px;border-radius:50%;border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:0.88rem;color:var(--muted);transition:all 0.2s;}
.ns:hover{border-color:var(--gold);color:var(--gold);}
.ns.wa:hover{border-color:var(--wa);color:var(--wa);}
.ns.yt:hover{border-color:var(--yt);color:var(--yt);}
.nav-cta{font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;padding:0.5rem 1.3rem;border:1px solid var(--gold);color:var(--gold);transition:all 0.22s;white-space:nowrap;margin-left:0.5rem;}
.nav-cta:hover{background:var(--gold);color:var(--black);}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px;}
.hamburger span{width:22px;height:1px;background:var(--gold);transition:all 0.3s;}

/* Mobile menu */
.mob-menu{
  display:none;position:fixed;inset:0;z-index:800;
  background:rgba(8,7,6,0.99);
  flex-direction:column;align-items:center;justify-content:center;gap:1.75rem;
}
.mob-menu.open{display:flex;}
.mob-close{position:absolute;top:1.25rem;right:6%;background:none;border:none;color:var(--muted);font-size:1.6rem;cursor:pointer;}
.mob-menu a{font-family:'Cinzel',serif;font-size:1rem;letter-spacing:0.2em;color:var(--muted);transition:color 0.2s;}
.mob-menu a:hover{color:var(--gold);}
.mob-soc{display:flex;gap:1.5rem;margin-top:0.5rem;}
.mob-soc a{font-size:1.25rem;color:var(--muted);transition:color 0.2s;}
.mob-soc a:hover{color:var(--gold);}
.mob-soc a.wa:hover{color:var(--wa);}
.mob-soc a.yt:hover{color:var(--yt);}

/* ━━━ HERO ━━━ */
#hero{min-height:calc(100vh - 60px);display:grid;grid-template-columns:1fr 1fr;align-items:stretch;}
.hero-l{display:flex;flex-direction:column;justify-content:center;padding:5rem 4% 5rem 0;}
.eyebrow{font-size:0.6rem;letter-spacing:0.35em;text-transform:uppercase;color:var(--gold);margin-bottom:1.75rem;display:flex;align-items:center;gap:0.85rem;opacity:0;animation:rise 0.8s ease 0.2s forwards;}
.eyebrow::before{content:'';width:26px;height:1px;background:var(--gold);}
.hname{font-family:'Cormorant Garamond',serif;font-size:clamp(3rem,5.2vw,6rem);font-weight:300;line-height:1;color:var(--white);opacity:0;animation:rise 0.9s ease 0.4s forwards;}
.hname em{color:var(--gold);display:block;font-style:normal;}
.gbar{width:44px;height:1px;background:linear-gradient(90deg,var(--gold),transparent);margin:1.75rem 0;}
.htag{font-family:'Cormorant Garamond',serif;font-size:clamp(0.95rem,1.4vw,1.15rem);font-weight:300;font-style:italic;color:var(--cream2);line-height:1.85;max-width:400px;opacity:0;animation:rise 0.8s ease 0.7s forwards;}
.htag strong{font-style:normal;color:var(--gold-lt);font-weight:400;}
.hbtns{display:flex;flex-wrap:wrap;gap:0.85rem;margin-top:2.25rem;opacity:0;animation:rise 0.8s ease 0.9s forwards;}
.btn-g{font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;padding:0.9rem 2rem;background:var(--gold);color:var(--black);font-weight:600;border:none;cursor:pointer;transition:all 0.22s;display:inline-flex;align-items:center;gap:0.5rem;}
.btn-g:hover{background:var(--gold-lt);transform:translateY(-2px);}
.btn-o{font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;padding:0.9rem 2rem;background:transparent;color:var(--cream);border:1px solid rgba(255,255,255,0.16);cursor:pointer;transition:all 0.22s;display:inline-flex;align-items:center;gap:0.5rem;}
.btn-o:hover{border-color:var(--gold);color:var(--gold);}

/* Countdown */
.countdown-wrap{margin-top:2.5rem;padding-top:2rem;border-top:1px solid var(--border2);opacity:0;animation:rise 0.8s ease 1.1s forwards;}
.cd-label{font-size:0.58rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--muted);margin-bottom:0.85rem;display:flex;align-items:center;gap:0.75rem;}
.cd-label::before{content:'';width:18px;height:1px;background:var(--muted);}
.cd-blocks{display:flex;gap:1.25rem;}
.cd-block{text-align:center;}
.cd-num{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:300;color:var(--gold);line-height:1;display:block;}
.cd-unit{font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--muted);}

/* Vote strip */
.hstrip{margin-top:2rem;padding-top:1.75rem;border-top:1px solid var(--border2);display:flex;align-items:center;gap:1.75rem;opacity:0;animation:rise 0.8s ease 1.3s forwards;}
.hs-n{font-family:'Cormorant Garamond',serif;font-size:2.6rem;font-weight:300;color:var(--gold);line-height:1;}
.hs-l{font-size:0.58rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--muted);margin-top:0.2rem;}
.live-dot{width:8px;height:8px;border-radius:50%;background:#4ADE80;box-shadow:0 0 0 0 rgba(74,222,128,0.4);animation:ping 1.5s ease infinite;flex-shrink:0;}

.hero-r{position:relative;overflow:hidden;}
.hero-r img{width:100%;height:100%;object-fit:cover;object-position:top center;}
.hgrad{position:absolute;inset:0;background:linear-gradient(to right,var(--black) 0%,transparent 18%),linear-gradient(to top,var(--black) 0%,transparent 22%);}
.hgold{position:absolute;top:0;left:0;bottom:0;width:2px;background:linear-gradient(to bottom,transparent,var(--gold),transparent);opacity:0.35;}

/* Hero stats row */
.hero-stats{display:flex;gap:2.5rem;margin-top:1.75rem;flex-wrap:wrap;opacity:0;animation:rise 0.8s ease 1.5s forwards;}
.hstat-item{display:flex;flex-direction:column;}
.hstat-v{font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:300;color:var(--gold);line-height:1;}
.hstat-l{font-size:0.55rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);}

/* ━━━ SECTIONS ━━━ */
.sec{padding:5.5rem 6%;}
.sec-in{max-width:960px;margin:0 auto;}
.lbl{font-size:0.57rem;letter-spacing:0.4em;text-transform:uppercase;color:var(--gold);margin-bottom:0.85rem;display:flex;align-items:center;gap:0.85rem;}
.lbl::before{content:'';width:20px;height:1px;background:var(--gold);}
.h2{font-family:'Cormorant Garamond',serif;font-size:clamp(2.2rem,4vw,4rem);font-weight:300;line-height:1.1;color:var(--white);margin-bottom:0.9rem;}
.h2 .g{color:var(--gold);}
.body{font-size:0.88rem;color:var(--muted);line-height:1.9;max-width:560px;}
.body strong{color:var(--cream);font-weight:500;}
.gb{width:40px;height:1px;background:var(--gold);margin:1.5rem 0;}

/* ━━━ GAPLA ━━━ */
#gapla{background:var(--dark);}
.gapla-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;margin-top:3rem;align-items:start;}
.gcards{display:flex;flex-direction:column;gap:1px;}
.gc{background:var(--card);padding:1.6rem 1.75rem;border-left:2px solid transparent;transition:all 0.28s;}
.gc:hover{border-color:var(--gold);background:#211F1A;}
.gc-n{font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:300;color:var(--gold);margin-bottom:0.5rem;line-height:1;}
.gc-t{font-family:'Cinzel',serif;font-size:0.72rem;letter-spacing:0.12em;color:var(--white);margin-bottom:0.35rem;}
.gc-b{font-size:0.8rem;color:var(--muted);line-height:1.7;}

/* ━━━ MANIFESTO ━━━ */
#manifesto{background:var(--black);}
.pillars{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border2);margin-top:3rem;}
.pillar{background:var(--card);padding:2.5rem 2rem;position:relative;overflow:hidden;transition:background 0.28s;opacity:0;transform:translateY(16px);}
.pillar.vis{opacity:1;transform:translateY(0);transition:opacity 0.55s ease,transform 0.55s ease;}
.pillar:hover{background:#211F1A;}
.pillar::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform 0.38s ease;}
.pillar:hover::after{transform:scaleX(1);}
.p-bg{font-family:'Cormorant Garamond',serif;font-size:4.5rem;font-weight:300;color:rgba(200,169,110,0.06);position:absolute;top:0.5rem;right:1rem;line-height:1;}
.p-ic{font-size:1.3rem;margin-bottom:1rem;}
.p-t{font-family:'Cinzel',serif;font-size:0.78rem;letter-spacing:0.1em;color:var(--gold);margin-bottom:0.6rem;}
.p-b{font-size:0.8rem;color:var(--muted);line-height:1.8;}
.p-pts{margin-top:1rem;display:flex;flex-direction:column;gap:0.4rem;}
.pp{display:flex;gap:0.65rem;font-size:0.78rem;color:var(--cream2);}
.pp::before{content:'—';color:var(--gold);flex-shrink:0;}

/* ━━━ SHARE BANNER ━━━ */
.share-banner{background:var(--dark2);border-top:1px solid var(--border2);border-bottom:1px solid var(--border2);padding:2.5rem 6%;text-align:center;}
.sb-label{font-size:0.6rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--muted);margin-bottom:1.25rem;}
.sb-title{font-family:'Cormorant Garamond',serif;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:300;color:var(--white);margin-bottom:1.5rem;}
.sb-title .g{color:var(--gold);}
.share-btns{display:flex;flex-wrap:wrap;gap:0.85rem;justify-content:center;}
.sbtn{display:inline-flex;align-items:center;gap:0.5rem;font-size:0.62rem;letter-spacing:0.15em;text-transform:uppercase;padding:0.75rem 1.5rem;border:1px solid var(--border);color:var(--muted);background:var(--card);cursor:pointer;transition:all 0.22s;}
.sbtn:hover{border-color:var(--gold);color:var(--gold);}
.sbtn.wa-s:hover{border-color:var(--wa);color:var(--wa);}
.sbtn.copied{border-color:#4ADE80;color:#4ADE80;}

/* ━━━ VOTE ━━━ */
#vote{background:var(--dark);}
.vote-c{max-width:500px;margin:0 auto;text-align:center;}
.vote-live{display:flex;align-items:center;justify-content:center;gap:0.65rem;font-size:0.57rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--muted);margin-bottom:1.25rem;}
.vote-num{font-family:'Cormorant Garamond',serif;font-size:clamp(4.5rem,10vw,8rem);font-weight:300;line-height:1;color:var(--gold);display:block;}
.vote-sub{font-size:0.6rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--muted);}

/* Flag ticker */
.flag-ticker{margin:1.5rem auto 0;max-width:440px;display:flex;flex-wrap:wrap;gap:0.35rem;justify-content:center;}
.ftag{font-size:0.7rem;padding:0.2rem 0.4rem;background:var(--card);border:1px solid var(--border2);color:var(--muted);}

.vote-box{border:1px solid var(--border);padding:2.5rem 2.25rem;background:var(--card);margin-top:2.5rem;}
.vote-btn{width:100%;font-size:0.65rem;letter-spacing:0.22em;text-transform:uppercase;padding:1.1rem 2rem;background:var(--gold);color:var(--black);font-weight:600;border:none;cursor:pointer;transition:all 0.22s;margin-bottom:0.75rem;}
.vote-btn:hover:not(:disabled){background:var(--gold-lt);transform:translateY(-2px);}
.vote-btn:disabled{opacity:0.35;cursor:not-allowed;}
.v-note{font-size:0.58rem;letter-spacing:0.12em;color:var(--muted);text-transform:uppercase;}
.v-msg{min-height:1.3em;font-size:0.65rem;letter-spacing:0.12em;color:var(--gold);text-transform:uppercase;margin-top:0.75rem;}
.open-to{margin-top:1.5rem;font-size:0.62rem;letter-spacing:0.1em;color:var(--muted);line-height:1.9;}

/* ━━━ FAQ ━━━ */
#faq{background:var(--black);}
.faq-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border2);margin-top:3rem;}
.fq{background:var(--card);padding:2rem 2rem;border-left:2px solid transparent;transition:all 0.28s;cursor:default;}
.fq:hover{border-color:var(--gold);background:#211F1A;}
.fq-q{font-family:'Cinzel',serif;font-size:0.8rem;letter-spacing:0.08em;color:var(--white);margin-bottom:0.65rem;display:flex;align-items:flex-start;gap:0.75rem;}
.fq-q::before{content:'Q.';color:var(--gold);flex-shrink:0;font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:300;}
.fq-a{font-size:0.82rem;color:var(--muted);line-height:1.8;padding-left:1.5rem;}

/* ━━━ CONTACT ━━━ */
#contact{background:var(--dark2);}
.contact-grid{display:grid;grid-template-columns:1fr 1.25fr;gap:4.5rem;margin-top:3rem;align-items:start;}
.social-ways{display:flex;flex-direction:column;gap:1px;margin-top:1.5rem;}
.sw{display:flex;align-items:center;gap:1.1rem;padding:1.15rem 1.4rem;background:var(--card);border:1px solid transparent;transition:all 0.28s;text-decoration:none;}
.sw:hover{border-color:var(--gold);background:#211F1A;}
.sw-ic{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;border:1px solid var(--border);transition:all 0.28s;}
.sw.wa .sw-ic{color:var(--wa);}
.sw.gm .sw-ic{color:var(--gold);}
.sw.tt .sw-ic{color:var(--cream);}
.sw.yt .sw-ic{color:var(--yt);}
.sw:hover .sw-ic{background:var(--border2);}
.sw-lbl{font-size:0.57rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);margin-bottom:0.15rem;}
.sw-val{font-size:0.82rem;color:var(--cream);font-weight:400;}
.sform{display:flex;flex-direction:column;gap:1rem;}
.fl{font-size:0.57rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--gold);margin-bottom:0.3rem;display:block;}
.fi,.fs,.ft{width:100%;background:var(--card);border:1px solid var(--border2);color:var(--cream);font-family:'Inter',sans-serif;font-size:0.85rem;font-weight:300;padding:0.78rem 0.95rem;outline:none;transition:border-color 0.2s;border-radius:0;}
.fi:focus,.fs:focus,.ft:focus{border-color:var(--gold);}
.fi::placeholder{color:var(--muted);}
.ft{resize:vertical;min-height:105px;}
.fs option{background:var(--card);}
.fsub{width:100%;font-size:0.6rem;letter-spacing:0.22em;text-transform:uppercase;padding:1rem 2rem;background:transparent;border:1px solid var(--gold);color:var(--gold);cursor:pointer;transition:all 0.22s;font-weight:500;}
.fsub:hover{background:var(--gold);color:var(--black);}
.form-done{display:none;text-align:center;padding:3rem 1rem;font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-style:italic;color:var(--gold);line-height:1.7;}

/* ━━━ DONATE ━━━ */
#donate{background:var(--dark);}
.donate-note-top{margin-bottom:2rem;padding:1.25rem 1.75rem;border:1px solid var(--border);background:var(--card);font-size:0.8rem;color:var(--muted);line-height:1.8;}
.donate-note-top strong{color:var(--gold-lt);}
.dcards{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border2);}
.dc{background:var(--card);padding:2.25rem 1.75rem;transition:background 0.28s;}
.dc:hover{background:#211F1A;}
.dc-ic{font-size:1.25rem;margin-bottom:1rem;}
.dc-t{font-family:'Cinzel',serif;font-size:0.75rem;letter-spacing:0.1em;color:var(--gold);margin-bottom:0.75rem;}
.dc-b{font-size:0.78rem;color:var(--muted);line-height:1.9;}
.dc-b strong{color:var(--cream);display:block;margin-top:0.35rem;}
.d-pledge{margin-top:2rem;padding:1.5rem 1.75rem;border:1px solid var(--border);font-size:0.8rem;color:var(--muted);line-height:1.8;text-align:center;}
.d-pledge strong{color:var(--gold);}

/* ━━━ FOOTER ━━━ */
footer{background:var(--dark2);border-top:1px solid var(--border2);}
.foot-top{padding:2.5rem 6%;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1.75rem;}
.foot-brand{font-family:'Cinzel',serif;font-size:0.78rem;letter-spacing:0.22em;color:var(--gold);}
.foot-soc{display:flex;gap:0.85rem;}
.fsoc{width:36px;height:36px;border-radius:50%;border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:0.9rem;color:var(--muted);transition:all 0.22s;}
.fsoc:hover{border-color:var(--gold);color:var(--gold);}
.fsoc.wa:hover{border-color:var(--wa);color:var(--wa);}
.fsoc.yt:hover{border-color:var(--yt);color:var(--yt);}
.foot-bot{padding:1.1rem 6%;border-top:1px solid var(--border2);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.75rem;}
.foot-copy{font-size:0.57rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);}
.foot-by{font-size:0.57rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);}
.foot-by a{color:var(--gold);}

/* Floating WA */
.wa-float{position:fixed;bottom:1.75rem;right:1.75rem;z-index:500;width:50px;height:50px;border-radius:50%;background:var(--wa);display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:#fff;box-shadow:0 4px 18px rgba(37,211,102,0.35);transition:all 0.22s;text-decoration:none;}
.wa-float:hover{transform:scale(1.1);}
.wa-tip{position:absolute;right:58px;background:var(--card);border:1px solid var(--border);font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--cream);padding:0.35rem 0.7rem;white-space:nowrap;opacity:0;transform:translateX(6px);transition:all 0.2s;pointer-events:none;}
.wa-float:hover .wa-tip{opacity:1;transform:translateX(0);}

/* Back to top */
.btt{position:fixed;bottom:1.75rem;left:1.75rem;z-index:500;width:40px;height:40px;border-radius:50%;background:var(--card);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:0.9rem;color:var(--gold);cursor:pointer;opacity:0;pointer-events:none;transition:all 0.22s;}
.btt.show{opacity:1;pointer-events:all;}
.btt:hover{background:var(--gold);color:var(--black);}

/* ━━━ ANIMATIONS ━━━ */
@keyframes rise{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}
@keyframes ping{0%,100%{box-shadow:0 0 0 0 rgba(74,222,128,0.4);}50%{box-shadow:0 0 0 8px rgba(74,222,128,0);}}
.reveal{opacity:0;transform:translateY(16px);transition:opacity 0.65s ease,transform 0.65s ease;}
.reveal.vis{opacity:1;transform:translateY(0);}

/* ━━━ RESPONSIVE ━━━ */
@media(max-width:960px){
  .sec{padding:4rem 5%;}
  #hero{grid-template-columns:1fr;min-height:auto;}
  .hero-l{padding:4rem 5% 0;}
  .hero-r{height:65vw;min-height:300px;}
