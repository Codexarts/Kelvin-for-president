async function fetchVotes(){
  try{ const r = await fetch(API,{cache:'no-store'}); if(r.ok){ const d=await r.json(); setCount(d.count??0); } }
  catch(e){}
}

async function castVote(){
  const btn = document.getElementById('voteBtn');
  const msg = document.getElementById('vMsg');
  if(localStorage.getItem(VKEY)){ msg.textContent='✓ You have already voted. Thank you.'; return; }
  btn.disabled = true;
  btn.innerHTML = '<i class="ri-loader-4-line"></i>&nbsp; Counting your vote…';
  try{
    const r = await fetch(API+'/up',{cache:'no-store'});
    if(r.ok){
      const d = await r.json(); setCount(d.count??0);
      localStorage.setItem(VKEY,'1');
      btn.innerHTML = '<i class="ri-checkbox-circle-fill"></i>&nbsp; Vote Cast — Thank you!';
      msg.textContent = 'Your vote has been counted. Welcome to Gapla.';
    } else throw new Error();
  } catch(e){
    btn.disabled=false;
    btn.innerHTML='<i class="ri-checkbox-circle-line"></i>&nbsp; Vote for Kelvin Saitabau';
    msg.textContent='Connection error — please try again.';
  }
}

fetchVotes();
setInterval(fetchVotes, 5000);

if(localStorage.getItem(VKEY)){
  document.addEventListener('DOMContentLoaded', () => {
    const b = document.getElementById('voteBtn');
    if(b){ b.disabled=true; b.innerHTML='<i class="ri-checkbox-circle-fill"></i>&nbsp; Already Voted — Thank you!'; }
  });
}

// ━━ SHARE BUTTONS ━━
const SITE_URL = window.location.href;
const SITE_TEXT = 'Vote for Kelvin Saitabau as President of Gapla — a new nation built by Gen Z, open to every nationality on Earth.';

function shareWA(){
  window.open('https://wa.me/?text='+encodeURIComponent(SITE_TEXT+' '+SITE_URL),'_blank');
}
function shareX(){
  window.open('https://x.com/intent/tweet?text='+encodeURIComponent(SITE_TEXT)+'&url='+encodeURIComponent(SITE_URL),'_blank');
}
function copyLink(){
  navigator.clipboard.writeText(SITE_URL).then(() => {
    const btn = document.getElementById('copyBtn');
    btn.classList.add('copied');
    btn.innerHTML='<i class="ri-check-line"></i> Copied!';
    setTimeout(() => { btn.classList.remove('copied'); btn.innerHTML='<i class="ri-links-line"></i> Copy Link'; }, 2200);
  });
}

// ━━ FORM ━━
function submitForm(e){
  e.preventDefault();
  const form=document.getElementById('sForm'), done=document.getElementById('formDone');
  fetch('/',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:new URLSearchParams(new FormData(form)).toString()})
    .then(()=>{ form.style.display='none'; done.style.display='block'; })
    .catch(()=>{ form.style.display='none'; done.style.display='block'; });
}
</script>
